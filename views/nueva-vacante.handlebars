<main class="contenedor">
  <form action="/vacantes/nueva" method="POST" class="default-form">
    <h3>Información General</h3>
    <div class="campo">
        <label>Titulo</label>
        <input type="text" name="titulo" placeholder="Ej: React Developer" required>
    </div>
    <div class="campo">
        <label>Empresa</label>
        <input type="text" name="empresa" placeholder="Ej: Rappi" required>
    </div>
    <div class="campo">
        <label>Ubicación</label>
        <input type="text" name="ubicacion" placeholder="Ej: Bogotá" required>
    </div>
    <div class="campo">
        <label>Salario (COP)</label>
        <input type="text" name="salario" placeholder="Ej: $1200000" required>
    </div>
    <div class="campo">
        <label>Contrato</label>
        <select name="contrato">
            <option value="" disabled selected>-- Selecciona --</option>
            <option value="Freelance">Freelance</option>
            <option value="Tiempo Completo">Tiempo Completo</option>
            <option value="Medio Tiempo">Medio Tiempo</option>
            <option value="Por Proyecto">Por Proyecto</option>
        </select>
    </div>
    <h3>Descripción del puesto</h3>
  </form>
</main>